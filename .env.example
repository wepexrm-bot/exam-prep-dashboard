# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/gate-prep?retryWrites=true&w=majority

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-random-64-byte-hex-string

# Admin credentials (used on first run to seed the DB)
ADMIN_USER=admin
ADMIN_PASS=your-password

# Next.js
NEXTAUTH_URL=http://localhost:3000
