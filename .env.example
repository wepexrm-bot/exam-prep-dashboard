# MongoDB Atlas connection string
# ⚠️  Replace with your own connection string! DO NOT commit real credentials.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/gate-prep?retryWrites=true&w=majority

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-random-64-byte-hex-string

# Gmail SMTP credentials (for sending verification emails)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Next.js
NEXTAUTH_URL=http://localhost:3000
